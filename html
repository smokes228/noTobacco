<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Счётчик времени</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="container">
        <h1>Счётчик времени</h1>
        <div id="timeDisplay" class="time-display">
            <p id="days">Дни: 0</p>
            <p id="hours">Часы: 0</p>
            <p id="minutes">Минуты: 0</p>
        </div>
        <button id="startButton" onclick="startTimer()">Старт</button>
    </div>
    <script src="script.js"></script>
</body>
</html>
